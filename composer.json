{
  "name": "catalisi/cetus-media-optimizer",
  "description": "Advanced media optimizer for WordPress: AVIF/WebP conversion, AI Alt Text and orphan file management.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Catalisi",
      "homepage": "https://github.com/catalisidev"
    }
  ],
  "require": {
    "php": ">=8.0",
    "sentry/sentry": "^4.0"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcsstandards/phpcsutils": "^1.0",
    "phpcsstandards/phpcsextra": "^1.2",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.0.0"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "phpcs": "phpcs --standard=phpcs.xml.dist",
    "phpcbf": "phpcbf --standard=phpcs.xml.dist",
    "pot": "wp i18n make-pot . languages/cetus-media-optimizer.pot --domain=cetus-media-optimizer --exclude=vendor,node_modules",
    "lint": [
      "@phpcs"
    ],
    "build": [
      "composer install --no-dev --optimize-autoloader --no-interaction",
      "@remove-vendor-extras"
    ],
    "zip": "bash bin/build-zip.sh",
    "remove-vendor-extras": [
      "find vendor -type d -name 'tests' -exec rm -rf {} + 2>/dev/null || true",
      "find vendor -type d -name 'test' -exec rm -rf {} + 2>/dev/null || true",
      "find vendor -type d -name 'Tests' -exec rm -rf {} + 2>/dev/null || true",
      "find vendor -type d -name 'docs' -exec rm -rf {} + 2>/dev/null || true",
      "find vendor -type d -name 'examples' -exec rm -rf {} + 2>/dev/null || true",
      "find vendor -name 'phpunit.xml*' -delete 2>/dev/null || true",
      "find vendor -name '.travis.yml' -delete 2>/dev/null || true",
      "find vendor -name 'CHANGELOG*' -delete 2>/dev/null || true",
      "find vendor -name 'CONTRIBUTING*' -delete 2>/dev/null || true"
    ]
  },
  "autoload": {
    "exclude-from-classmap": [
      "vendor/sentry/sentry/tests/",
      "vendor/sentry/sentry/dev-packages/"
    ]
  }
}
