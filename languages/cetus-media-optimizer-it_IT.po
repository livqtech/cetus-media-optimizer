#. Description of the plugin
#: cetus-media-optimizer.php
msgid "Advanced media optimizer: converts images to AVIF/WebP, auto-generates Alt Text via AI (Gemini / OpenAI), detects orphan files and manages your media library. Evolution of Cetus WebP Converter."
msgstr "Ottimizzatore multimediale avanzato: converte le immagini in AVIF/WebP, genera automaticamente l'Alt Text tramite AI (Gemini / OpenAI), rileva i file orfani e gestisce la tua libreria multimediale. Evoluzione di Cetus WebP Converter."

#. Author of the plugin
#: cetus-media-optimizer.php
msgid "Catalisi"
msgstr "Catalisi"

#. Author URI of the plugin
#: cetus-media-optimizer.php
msgid "https://github.com/catalisidev"
