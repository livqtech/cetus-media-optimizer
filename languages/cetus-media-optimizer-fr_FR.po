msgstr "Permissions insuffisantes."

#, php-format
msgid "%1$d files deleted. %2$d errors."
msgstr "%1$d fichiers supprimés. %2$d erreurs."

msgid "Invalid request (nonce expired or missing)."
msgstr "Requête invalide (nonce expiré ou absent)."

