#. Plugin Name of the plugin
msgid "Cetus Media Optimizer"
msgstr "Cetus Media Optimizer"

#. Plugin URI of the plugin
msgid "https://github.com/catalisidev/cetus-media-optimizer"
msgstr ""

#. Description of the plugin
msgid "Advanced media optimizer: converts images to AVIF/WebP, auto-generates Alt Text via AI (Gemini / OpenAI), detects orphan files and manages your media library. Evolution of Cetus WebP Converter."
msgstr "Erweiterter Medien-Optimierer: Konvertiert Bilder in AVIF/WebP, generiert automatisch Alt-Text per KI (Gemini / OpenAI), erkennt verwaiste Dateien und verwaltet Ihre Medienbibliothek. Weiterentwicklung von Cetus WebP Converter."

#. Author of the plugin
msgid "Catalisi"
msgstr "Catalisi"

#. Author URI of the plugin
msgid "https://github.com/catalisidev"
msgstr ""

msgid "Every 5 minutes (Cetus MO)"
msgstr "Alle 5 Minuten (Cetus MO)"

msgid "A process is already running. Use Pause or Stop before restarting."
msgstr "Es läuft bereits ein Prozess. Bitte Pause oder Stopp verwenden, bevor ein neuer gestartet wird."

msgid "No images to optimize found in the library."
msgstr "Keine zu optimierenden Bilder in der Bibliothek gefunden."

#, php-format
msgid "Process started. %d images queued."
msgstr "Prozess gestartet. %d Bilder in der Warteschlange."

msgid "No active process."
msgstr "Kein aktiver Prozess."

msgid "No process running."
msgstr "Kein Prozess läuft."

msgid "Process paused."
msgstr "Prozess angehalten."

msgid "No paused process to resume."
msgstr "Kein angehaltener Prozess zum Fortsetzen."

msgid "Lock active: cannot resume."
msgstr "Sperre aktiv: Fortsetzen nicht möglich."

msgid "Process resumed."
msgstr "Prozess fortgesetzt."

msgid "Process stopped and queue cleared."
msgstr "Prozess gestoppt und Warteschlange geleert."

#, php-format
msgid "Found %d orphan files."
msgstr "%d verwaiste Dateien gefunden."

msgid "No orphan files found."
msgstr "Keine verwaisten Dateien gefunden."

#, php-format
msgid "%1$d orphan files optimized. Savings: %2$s MB."
msgstr "%1$d verwaiste Dateien optimiert. Ersparnis: %2$s MB."

msgid "Insufficient permissions."
msgstr "Unzureichende Berechtigungen."

#, php-format
msgid "%1$d files deleted. %2$d errors."
msgstr "%1$d Dateien gelöscht. %2$d Fehler."

msgid "Invalid request (nonce expired or missing)."
msgstr "Ungültige Anfrage (Nonce abgelaufen oder fehlend)."

msgid "Cetus Media"
msgstr "Cetus Media"

msgid "Start Optimization"
msgstr "Optimierung starten"

msgid "Pause"
msgstr "Pause"

msgid "Resume"
msgstr "Fortsetzen"

msgid "Stop"
msgstr "Stopp"

msgid "Scanning…"
msgstr "Wird gescannt…"

msgid "Processing…"
msgstr "Wird verarbeitet…"

msgid "Done!"
msgstr "Fertig!"

msgid "Server communication error."
msgstr "Kommunikationsfehler mit dem Server."

msgid "Are you sure you want to optimize the orphan files found?"
msgstr "Möchten Sie die gefundenen verwaisten Dateien wirklich optimieren?"

msgid "Settings saved."
msgstr "Einstellungen gespeichert."

msgid "Valid key format."
msgstr "Gültiges Schlüsselformat."

msgid "Invalid key format."
msgstr "Ungültiges Schlüsselformat."

msgid "Access denied."
msgstr "Zugriff verweigert."

msgid "Server Diagnosis"
msgstr "Server-Diagnose"

msgid "Preferences"
msgstr "Einstellungen"

msgid "Library Management"
msgstr "Bibliotheksverwaltung"

msgid "Server correctly configured"
msgstr "Server korrekt konfiguriert"

msgid "all required libraries are available."
msgstr "alle erforderlichen Bibliotheken sind verfügbar."

msgid "Partial configuration"
msgstr "Teilkonfiguration"

msgid "some features may not be available."
msgstr "Einige Funktionen sind möglicherweise nicht verfügbar."

msgid "Component"
msgstr "Komponente"

msgid "Status"
msgstr "Status"

msgid "Notes"
msgstr "Hinweise"

msgid "Go to Preferences →"
msgstr "Zu den Einstellungen →"

msgid "PHP Version"
msgstr "PHP-Version"

msgid "Requires PHP 8.0 or higher."
msgstr "Erfordert PHP 8.0 oder höher."

msgid "Imagick Extension"
msgstr "Imagick-Erweiterung"

#, php-format
msgid "Available (v%s)"
msgstr "Verfügbar (v%s)"

msgid "Not available"
msgstr "Nicht verfügbar"

msgid "Contact your hosting provider to enable Imagick."
msgstr "Wenden Sie sich an Ihren Hosting-Anbieter, um Imagick zu aktivieren."

msgid "GD Extension"
msgstr "GD-Erweiterung"

msgid "Available"
msgstr "Verfügbar"

msgid "WebP Support (Imagick)"
msgstr "WebP-Unterstützung (Imagick)"

msgid "Supported"
msgstr "Unterstützt"

msgid "Not supported"
msgstr "Nicht unterstützt"

msgid "Available via GD as fallback."
msgstr "Über GD als Fallback verfügbar."

msgid "WebP Support (GD)"
msgstr "WebP-Unterstützung (GD)"

msgid "AVIF Support (Imagick)"
msgstr "AVIF-Unterstützung (Imagick)"

msgid "Imagick declares AVIF support but real encoding produces empty files (libheif not working). The plugin will fall back to WebP."
msgstr "Imagick erklärt AVIF-Unterstützung, aber die tatsächliche Kodierung erzeugt leere Dateien (libheif funktioniert nicht). Das Plugin verwendet WebP als Fallback."

msgid "Requires libheif/libavif compiled with Imagick."
msgstr "Erfordert libheif/libavif, kompiliert mit Imagick."

msgid "AVIF Support (GD)"
msgstr "AVIF-Unterstützung (GD)"

msgid "Requires PHP ≥ 8.1 with libavif."
msgstr "Erfordert PHP ≥ 8.1 mit libavif."

msgid "Automatic (AVIF if available, otherwise WebP)"
msgstr "Automatisch (AVIF wenn verfügbar, sonst WebP)"

msgid "AVIF only"
msgstr "Nur AVIF"

msgid "WebP only"
msgstr "Nur WebP"

msgid "No conversion (Alt Text AI only)"
msgstr "Keine Konvertierung (nur KI-Alt-Text)"

msgid "Automatic (from WordPress locale)"
msgstr "Automatisch (aus WordPress-Sprache)"

msgid "API key active: Alt Text will be generated automatically on every new upload."
msgstr "API-Schlüssel aktiv: Alt-Text wird bei jedem neuen Upload automatisch generiert."

msgid "Enter at least one API key to enable automatic Alt Text generation."
msgstr "Geben Sie mindestens einen API-Schlüssel ein, um die automatische Alt-Text-Generierung zu aktivieren."

msgid "Output Format"
msgstr "Ausgabeformat"

msgid "Conversion format"
msgstr "Konvertierungsformat"

msgid "\"Automatic\" selects AVIF if the server supports it, WebP as fallback."
msgstr "\"Automatisch\" wählt AVIF, wenn der Server es unterstützt, WebP als Fallback."

msgid "New Uploads"
msgstr "Neue Uploads"

msgid "Automatically convert new images on upload"
msgstr "Neue Bilder beim Upload automatisch konvertieren"

msgid "Not available when format is set to \"No conversion\"."
msgstr "Nicht verfügbar, wenn das Format auf \"Keine Konvertierung\" gesetzt ist."

msgid "Conversion Quality"
msgstr "Konvertierungsqualität"

msgid "Higher values = better quality but larger files (default: 82)."
msgstr "Höhere Werte = bessere Qualität, aber größere Dateien (Standard: 82)."

msgid "Higher values = better quality but larger files (default: 75)."
msgstr "Höhere Werte = bessere Qualität, aber größere Dateien (Standard: 75)."

msgid "AI Assistant – Alt Text Generation"
msgstr "KI-Assistent – Alt-Text-Generierung"

msgid "Monitor your API key quota limits. High usage can generate \"Quota Exceeded\" errors (429)."
msgstr "Überwachen Sie die Kontingentgrenzen Ihrer API-Schlüssel. Hohe Nutzung kann zu \"Quota Exceeded\"-Fehlern (429) führen."

msgid "Preferred AI provider"
msgstr "Bevorzugter KI-Anbieter"

msgid "AI provider"
msgstr "KI-Anbieter"

msgid "Google Gemini (gemini-1.5-flash)"
msgstr "Google Gemini (gemini-1.5-flash)"

msgid "OpenAI (gpt-4o-mini)"
msgstr "OpenAI (gpt-4o-mini)"

msgid "Automatic fallback"
msgstr "Automatischer Fallback"

msgid "Enable automatic fallback to the other provider on 429 errors"
msgstr "Automatischen Fallback zum anderen Anbieter bei 429-Fehlern aktivieren"

msgid "Google Gemini API Key"
msgstr "Google Gemini API-Schlüssel"

msgid "Verify"
msgstr "Überprüfen"

msgid "Expected format: AIzaSy… (39 characters). Get a key from Google AI Studio."
msgstr "Erwartetes Format: AIzaSy… (39 Zeichen). Schlüssel von Google AI Studio erhalten."

msgid "OpenAI API Key"
msgstr "OpenAI API-Schlüssel"

msgid "Expected format: sk-… Get a key from platform.openai.com."
msgstr "Erwartetes Format: sk-… Schlüssel von platform.openai.com erhalten."

msgid "Alt Text AI Language"
msgstr "KI-Alt-Text-Sprache"

#, php-format
msgid "With \"Automatic\" the current WordPress locale is used (%s)."
msgstr "Bei \"Automatisch\" wird die aktuelle WordPress-Sprache verwendet (%s)."

msgid "Custom prompt"
msgstr "Benutzerdefinierter Prompt"

msgid "Leave empty to use the default prompt."
msgstr "Leer lassen, um den Standard-Prompt zu verwenden."

msgid "Optional — overrides the language and default prompt. Example: \"Describe this image in English in one sentence.\""
msgstr "Optional — überschreibt Sprache und Standard-Prompt. Beispiel: \"Describe this image in English in one sentence.\""

msgid "Background (WP-Cron)"
msgstr "Hintergrund (WP-Cron)"

msgid "Process the library in the background via WP-Cron (every 5 min) without keeping the browser open"
msgstr "Bibliothek im Hintergrund per WP-Cron (alle 5 Min.) verarbeiten, ohne den Browser geöffnet zu halten"

msgid "Ideal for very large libraries or hosting with strict timeouts."
msgstr "Ideal für sehr große Bibliotheken oder Hosting mit strengen Timeouts."

msgid "Save Preferences"
msgstr "Einstellungen speichern"

msgid "Go to Library Management →"
msgstr "Zur Bibliotheksverwaltung →"

msgid "Library Statistics"
msgstr "Bibliotheksstatistiken"

msgid "Images in library"
msgstr "Bilder in der Bibliothek"

msgid "To convert"
msgstr "Zu konvertieren"

msgid "Total space"
msgstr "Gesamtspeicher"

msgid "Original JPG/PNG/GIF"
msgstr "Originale JPG/PNG/GIF"

msgid "WebP files"
msgstr "WebP-Dateien"

msgid "AVIF files"
msgstr "AVIF-Dateien"

msgid "Current session savings"
msgstr "Ersparnis der aktuellen Sitzung"

msgid "Cumulative total savings"
msgstr "Kumulierte Gesamtersparnis"

msgid "Start Library Optimization"
msgstr "Bibliotheksoptimierung starten"

msgid "Orphan File Analysis"
msgstr "Analyse verwaister Dateien"

msgid "Search for images in the uploads folder not registered in the WordPress database."
msgstr "Bilder im Uploads-Ordner suchen, die nicht in der WordPress-Datenbank registriert sind."

msgid "Scan Orphan Files"
msgstr "Verwaiste Dateien scannen"

msgid "Optimize orphan files found"
msgstr "Gefundene verwaiste Dateien optimieren"

msgid "Alt Text Generation"
msgstr "Alt-Text-Generierung"

msgid "images without Alt Text"
msgstr "Bilder ohne Alt-Text"

#, php-format
msgid "This operation will make API calls to OpenAI for each image. Check the <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">OpenAI pricing page</a> before proceeding."
msgstr "Dieser Vorgang führt für jedes Bild API-Aufrufe bei OpenAI durch. Prüfen Sie die <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">OpenAI-Preisseite</a> vor dem Fortfahren."

#, php-format
msgid "This operation will make API calls to Google Gemini for each image. Check the <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">Google AI pricing page</a> before proceeding."
msgstr "Dieser Vorgang führt für jedes Bild API-Aufrufe bei Google Gemini durch. Prüfen Sie die <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">Google AI-Preisseite</a> vor dem Fortfahren."

msgid "All images in the library already have an Alt Text."
msgstr "Alle Bilder in der Bibliothek haben bereits einen Alt-Text."

msgid "Generate Alt Text for library images that do not have one yet. The process uses the AI provider configured in Preferences."
msgstr "Alt-Text für Bibliotheksbilder generieren, die noch keinen haben. Der Prozess verwendet den in den Einstellungen konfigurierten KI-Anbieter."

msgid "Generate Alt Text for images without a description"
msgstr "Alt-Text für Bilder ohne Beschreibung generieren"

#, php-format
msgid "Configure at least one API key in %s to enable Alt Text generation."
msgstr "Konfigurieren Sie mindestens einen API-Schlüssel in %s, um die Alt-Text-Generierung zu aktivieren."

msgid "Restore Originals"
msgstr "Originale wiederherstellen"

msgid "Delete all WebP and AVIF files generated by the plugin. Original JPG/PNG/GIF files are never touched. Also resets the log and savings counter."
msgstr "Alle vom Plugin generierten WebP- und AVIF-Dateien löschen. Originaldateien JPG/PNG/GIF werden nie berührt. Setzt auch Protokoll und Ersparniszähler zurück."

msgid "Delete all converted files"
msgstr "Alle konvertierten Dateien löschen"

msgid "Conversion Log"
msgstr "Konvertierungsprotokoll"

msgid "Clear log"
msgstr "Protokoll leeren"

msgid "Telemetry"
msgstr "Telemetrie"

msgid "Anonymous crash reports"
msgstr "Anonyme Fehlerberichte"

msgid "Allow Cetus to send anonymous crash reports to help us improve the plugin."
msgstr "Cetus erlauben, anonyme Fehlerberichte zu senden, um das Plugin zu verbessern."

msgid "Error logs are fully anonymized and securely processed via Sentry. No IP address or personal data is ever collected. Read the <a href=\"https://sentry.io/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">Sentry Privacy Policy</a>."
msgstr "Fehlerprotokolle werden vollständig anonymisiert und sicher über Sentry verarbeitet. Es werden keine IP-Adressen oder personenbezogenen Daten erfasst. Lesen Sie die <a href=\"https://sentry.io/privacy/\" target=\"_blank\" rel=\"noopener noreferrer\">Sentry-Datenschutzrichtlinie</a>."

msgid "Active — reports sent to Sentry."
msgstr "Aktiv — Berichte an Sentry gesendet."

msgid "Disabled."
msgstr "Deaktiviert."

msgid "Invalid nonce."
msgstr "Ungültiger Nonce."

msgid "Settings saved successfully."
msgstr "Einstellungen erfolgreich gespeichert."

msgid "Exclude from conversion and Alt Text AI"
msgstr "Von Konvertierung und KI-Alt-Text ausschließen"

msgid "If checked, this image is skipped both during batch conversion and on upload."
msgstr "Wenn aktiviert, wird dieses Bild sowohl bei der Stapelkonvertierung als auch beim Upload übersprungen."

msgid "No conversions recorded yet."
msgstr "Noch keine Konvertierungen aufgezeichnet."

msgid "Date/Time"
msgstr "Datum/Uhrzeit"

msgid "File"
msgstr "Datei"

msgid "Format"
msgstr "Format"

msgid "Savings"
msgstr "Ersparnis"

#, php-format
msgid "Showing the last 50 of %d total entries."
msgstr "Die letzten 50 von %d Einträgen werden angezeigt."

msgid "Log cleared."
msgstr "Protokoll geleert."

msgid "Cetus Media Optimizer — Error Telemetry"
msgstr "Cetus Media Optimizer — Fehler-Telemetrie"

msgid "If the site administrator has enabled telemetry in the settings of <strong>Cetus Media Optimizer</strong>, the plugin sends anonymous PHP error reports to the <a href=\"https://sentry.io\" rel=\"noopener noreferrer\" target=\"_blank\">Sentry</a> service (sentry.io)."
msgstr "Wenn der Website-Administrator die Telemetrie in den Einstellungen von <strong>Cetus Media Optimizer</strong> aktiviert hat, sendet das Plugin anonyme PHP-Fehlerberichte an den <a href=\"https://sentry.io\" rel=\"noopener noreferrer\" target=\"_blank\">Sentry</a>-Dienst (sentry.io)."

msgid "The transmitted data includes exclusively: PHP error type, stack trace limited to plugin files, WordPress version, PHP version and plugin version. No IP address, username, site content or personal data is ever transmitted."
msgstr "Die übermittelten Daten umfassen ausschließlich: PHP-Fehlertyp, Stack-Trace auf Plugin-Dateien beschränkt, WordPress-Version, PHP-Version und Plugin-Version. Es werden keine IP-Adresse, Benutzername, Website-Inhalte oder personenbezogenen Daten übertragen."

msgid "This feature is disabled by default and requires explicit administrator consent. It can be disabled at any time from Cetus Media → Preferences → Telemetry."
msgstr "Diese Funktion ist standardmäßig deaktiviert und erfordert die ausdrückliche Zustimmung des Administrators. Sie kann jederzeit unter Cetus Media → Einstellungen → Telemetrie deaktiviert werden."

#, php-format
msgid "For more information see the <a href=\"%s\" rel=\"noopener noreferrer\" target=\"_blank\">Sentry Privacy Policy</a>."
msgstr "Weitere Informationen finden Sie in der <a href=\"%s\" rel=\"noopener noreferrer\" target=\"_blank\">Sentry-Datenschutzrichtlinie</a>."
