root = true

[*]
charset             = utf-8
end_of_line         = lf
insert_final_newline = true
trim_trailing_whitespace = true

# PHP — WordPress uses tabs
[*.php]
indent_style = tab
indent_size  = 4

# XML / JSON / YAML
[*.{xml,json,yml,yaml}]
indent_style = space
indent_size  = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# WordPress readme
[readme.txt]
indent_style = space
indent_size  = 4
